<title>归元 · 品牌宣言视频脚本</title>
<style>
    body { font-family: '微软雅黑', sans-serif; font-size: 11pt; color: #1a1a1a; line-height: 1.9; margin: 50px 60px; }
    h1 { font-size: 20pt; text-align: center; letter-spacing: 3px; margin-bottom: 2px; }
    h2 { font-size: 14pt; color: #1a1a1a; border-bottom: 2px solid #c5a14e; padding-bottom: 6px; margin-top: 32px; }
    h3 { font-size: 12pt; color: #444; margin-top: 18px; }
    .sub { text-align: center; color: #888; font-size: 11pt; margin-bottom: 30px; }
    table { border-collapse: collapse; width: 100%; margin: 14px 0; }
    th { background: #1a1a1a; color: #f5f5f0; padding: 8px 12px; text-align: left; font-size: 10pt; }
    td { border: 1px solid #ddd; padding: 10px 12px; font-size: 10.5pt; vertical-align: top; }
    tr:nth-child(even) { background: #faf9f6; }
    .script { background: #f5f4f0; padding: 20px 24px; border-left: 4px solid #c5a14e; margin: 12px 0; line-height: 2.2; font-size: 12pt; }
    .script em { color: #c5a14e; font-style: normal; font-weight: bold; }
